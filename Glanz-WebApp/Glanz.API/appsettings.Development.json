{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://get-it-cleaned-web-app.vercel.app"
    ]
  },
  "BusinessSettings": {
    "TimeZone": "W. Europe Standard Time"
  },
  "DevBypass": {
    "AllowDevBypass": true
  },
  "SeedData": {
    "ResetDatabaseOnStartup": false,
    "SeedDemoData": false
  },
  "AutoTranslation": {
    "Enabled": true,
    "SourceLanguage": "en",
    "TargetLanguages": [ "ar", "de" ],
    "Provider": "MyMemory",
    "MyMemoryUrl": "https://api.mymemory.translated.net/get",
    "LibreTranslateUrl": "https://libretranslate.com/translate",
    "LibreTranslateApiKey": "",
    "RequestTimeoutSeconds": 15
  }
}
