{
  "ConnectionStrings": {
    "DefaultConnection": "SET_IN_ENV_CONNECTIONSTRING"
  },
  "Google": {
    "PlacesApiKey": "YOUR_GOOGLE_PLACES_API_KEY",
    "PlaceId": "CbY8wgSE0iXGEAE"
  },
  "Authentication": {
    "Google": {
      "ClientId": "YOUR_GOOGLE_CLIENT_ID",
      "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
    }
  },
  "JwtSettings": {
    "SecretKey": "SET_IN_ENV_MIN_32_CHARS",
    "Issuer": "Glanz.API",
    "Audience": "Glanz.Client",
    "ExpirationMinutes": 720,
    "RefreshExpirationDays": 90
  },
  "TapPayments": {
    "SecretKey": "YOUR_TAP_SECRET_KEY",
    "PublishableKey": "YOUR_TAP_PUBLISHABLE_KEY",
    "WebhookSecret": "TODO: Set this to the signing key from your Tap dashboard (Developers → Webhooks). Without it, forged webhook events can mark unpaid bookings as paid."
  },
  "AddressAutocomplete": {
    "Enabled": true,
    "Provider": "Nominatim",
    "BaseUrl": "https://nominatim.openstreetmap.org/search",
    "CountryCode": "qa",
    "ResultLimit": 5
  },
  "AutoTranslation": {
    "Enabled": true,
    "SourceLanguage": "en",
    "TargetLanguages": [ "ar", "de" ],
    "Provider": "MyMemory",
    "MyMemoryUrl": "https://api.mymemory.translated.net/get",
    "LibreTranslateUrl": "https://libretranslate.com/translate",
    "LibreTranslateApiKey": "",
    "RequestTimeoutSeconds": 15
  },
  "AdminUser": {
    "Email": "admin@glanz.qa",
    "Password": "SET_DEV_ONLY_PASSWORD_IN_USER_SECRETS",
    "AutoSyncOnStartup": true,
    "FirstName": "Admin",
    "LastName": "User",
    "Phone": "+97444444444"
  },
  "AdminRecovery": {
    "Enabled": false,
    "Token": ""
  },
  "Bookings": {
    "AutoAssignEnabled": true
  },
  "Booking": {
    "WorkerTravelBufferMinutes": 30
  },
  "Anthropic": {
    "ApiKey": "YOUR_ANTHROPIC_API_KEY_HERE"
  },
  "CancellationPolicy": {
    "FeeEnabled": false,
    "FeeType": "Percent",
    "FeeAmount": 20.0,
    "FreeWindowHours": 24
  },
  "ObjectStorage": {
    "Provider": "Local",
    "BucketName": "",
    "Region": "auto",
    "ServiceUrl": "",
    "PublicBaseUrl": "",
    "AccessKey": "",
    "SecretKey": "",
    "KeyPrefix": "uploads",
    "UsePathStyle": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DevBypass": {
    "AllowDevBypass": false
  },
  "Email": {
    "SmtpHost": "TODO: e.g. smtp.gmail.com | smtp.sendgrid.net | sandbox.smtp.mailtrap.io",
    "SmtpPort": 587,
    "SmtpUser": "TODO: SMTP username or SendGrid API key (use 'apikey' as username for SendGrid)",
    "SmtpPassword": "TODO: SMTP password or SendGrid API key value — set via environment variable in production",
    "FromAddress": "noreply@glanz.qa",
    "FromName": "Glanz Car Detailing"
  },
  "Observability": {
    "SentryDsn": "TODO: Install Sentry.AspNetCore NuGet package, create a free project at sentry.io, paste the DSN here, then call builder.WebHost.UseSentry() in Program.cs"
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5289"
      }
    }
  }
}