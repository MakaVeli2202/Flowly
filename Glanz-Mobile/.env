# Production API base URL (used for production builds)
EXPO_PUBLIC_API_BASE_URL=https://glanz-api.onrender.com/api

# Development: Expo auto-detects the Metro bundler host. No manual IP needed.
# Local dev emulator/simulator fallback:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5289/api  (Android emulator)
# EXPO_PUBLIC_API_BASE_URL=http://localhost:5289/api (iOS simulator)

# Stripe publishable key — safe to commit test keys, NEVER commit secret keys.
# Replace with your actual key from https://dashboard.stripe.com/apikeys
# pk_test_ keys are for development; pk_live_ for production.
EXPO_PUBLIC_STRIPE_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY
