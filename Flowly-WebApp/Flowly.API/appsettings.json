    "ApiKey": ""
  },
  "Messaging": {
    "SmsRemindersEnabled": false,
    "ReminderHoursBefore": 24,
    "UseWhatsApp": false
  },
  "Infobip": {
    "BaseUrl": "https://api.infobip.com",
    "ApiKey": "",
    "SmsSender": "Flowly",
    "WhatsAppSender": ""
  },
  "FrontendUrl": "https://www.flowly.app",
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5289"
      }
