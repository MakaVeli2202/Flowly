{
  "brand": {
    "name": "Flowly",
    "tagline": "Premium Vehicle Detailing",
    "primary": "#C8A96B",
    "secondary": "#0EA5A0",
    "darkBg": "#0D1117",
    "panelBg": "#121A23",
    "lightText": "#E8E9EC"
  },

  "fonts": {
    "body": ["Manrope", "Segoe UI", "sans-serif"],
    "display": ["Cormorant Garamond", "Georgia", "serif"],
    "bodyWeights": [400, 500, 600, 700, 800],
    "displayWeights": [500, 600, 700]
  },

  "cssVariables": {
    "dark": {
      "--surface-bg": "#0d1117",
      "--surface-bg-alt": "#111927",
      "--text-color": "#e8e9ec",
      "--heading-color": "#ffffff",
      "--muted-color": "rgba(176, 184, 195, 0.9)",
      "--border-color": "rgba(255, 255, 255, 0.11)",
      "--border-strong": "rgba(255, 255, 255, 0.20)",
      "--nav-bg": "rgba(13, 17, 23, 0.78)",
      "--card-bg": "rgba(255, 255, 255, 0.05)",
      "--card-border": "rgba(255, 255, 255, 0.11)",
      "--cta-soft-bg": "rgba(255, 255, 255, 0.07)",
      "--cta-soft-hover-bg": "rgba(255, 255, 255, 0.13)",
      "--primary-rgb": "200, 169, 107",
      "--primary-bg": "rgba(200, 169, 107, 0.08)",
      "--primary-bg2": "rgba(200, 169, 107, 0.14)",
      "--primary-border": "rgba(200, 169, 107, 0.25)",
      "--shadow-heavy": "0 18px 45px rgba(0, 0, 0, 0.35)"
    },
    "light": {
      "--surface-bg": "#f3f5f8",
      "--surface-bg-alt": "#e8edf4",
      "--text-color": "#1c2430",
      "--heading-color": "#0b1320",
      "--muted-color": "rgba(26, 37, 50, 0.72)",
      "--border-color": "rgba(14, 23, 34, 0.12)",
      "--border-strong": "rgba(14, 23, 34, 0.22)",
      "--nav-bg": "rgba(244, 248, 255, 0.82)",
      "--card-bg": "rgba(255, 255, 255, 0.70)",
      "--card-border": "rgba(12, 22, 36, 0.10)",
      "--cta-soft-bg": "rgba(20, 28, 40, 0.06)",
      "--cta-soft-hover-bg": "rgba(20, 28, 40, 0.11)",
      "--shadow-heavy": "0 15px 36px rgba(25, 46, 76, 0.16)"
    }
  },

  "pageBackground": {
    "body": "radial-gradient(circle at 10% 15%, rgba(200,169,107,0.28), transparent 38%), radial-gradient(circle at 85% 8%, rgba(14,165,160,0.22), transparent 34%), radial-gradient(circle at 50% 55%, rgba(200,169,107,0.10), transparent 40%), radial-gradient(circle at 20% 80%, rgba(14,165,160,0.12), transparent 32%), linear-gradient(160deg, var(--surface-bg) 0%, var(--surface-bg-alt) 52%, var(--surface-bg) 100%)",
    "attention": "background-attachment: fixed"
  },

  "components": {
    "glassCard": {
      "borderRadius": "16px",
      "backdropBlur": "md",
      "border": "1px solid var(--card-border)",
      "background": "var(--card-bg)",
      "boxShadow": "var(--shadow-heavy)",
      "homepageOverride": {
        "background": "rgba(4, 7, 14, 0.44)",
        "backdropFilter": "blur(36px) saturate(210%) brightness(1.08)",
        "border": "1px solid rgba(255,255,255,0.09)",
        "boxShadow": "inset 0 1.5px 0 rgba(255,255,255,0.14), inset 0 -1px 0 rgba(0,0,0,0.14), 0 0 0 0.5px rgba(200,169,107,0.22), 0 28px 70px rgba(0,0,0,0.55), 0 0 90px rgba(200,169,107,0.07), 0 0 60px rgba(14,165,160,0.05)"
      }
    },
    "premiumHeading": {
      "fontFamily": "'Cormorant Garamond', Georgia, serif",
      "letterSpacing": "0.01em",
      "color": "var(--heading-color)"
    },
    "premiumButton": {
      "borderRadius": "12px",
      "background": "linear-gradient(135deg, #c8a96b 0%, #a88442 100%)",
      "color": "#101823",
      "fontWeight": 600,
      "boxShadow": "0 12px 35px rgba(200, 169, 107, 0.28)",
      "hover": {
        "transform": "translateY(-3px) scale(1.03)",
        "boxShadow": "0 22px 52px rgba(200,169,107,0.52), 0 0 0 1px rgba(200,169,107,0.38)"
      },
      "active": {
        "transform": "translateY(-1px) scale(0.985)"
      },
      "shimmer": "diagonal sweep ::after with skewX(-15deg), shimmering rgba(255,255,255,0.32)"
    },
    "secondaryCta": {
      "borderRadius": "12px",
      "border": "1px solid var(--border-color)",
      "background": "var(--cta-soft-bg)",
      "color": "var(--heading-color)",
      "fontWeight": 600,
      "hover": {
        "transform": "translateY(-3px)",
        "borderColor": "rgba(200,169,107,0.50)",
        "boxShadow": "0 14px 36px rgba(200,169,107,0.16)"
      }
    },
    "statCard": {
      "extends": "glassCard",
      "textAlign": "center",
      "minHeight": "110px",
      "topBorder": "1.5px gold-to-teal gradient",
      "statNumber": {
        "fontFamily": "'Cormorant Garamond', Georgia, serif",
        "fontSize": "2.75rem",
        "fontWeight": 700,
        "lineHeight": 1,
        "letterSpacing": "-0.01em",
        "fontVariantNumeric": "tabular-nums",
        "minWidth": "5ch",
        "glowAnimation": "statGlow 2.6s — text-shadow pulse + color shift to #f0d07a"
      },
      "statLabel": {
        "fontSize": "0.78rem",
        "fontWeight": 600,
        "letterSpacing": "0.18em",
        "textTransform": "uppercase",
        "color": "var(--muted-color)"
      }
    },
    "heroGlass": {
      "borderRadius": "20px",
      "background": "rgba(4, 6, 12, 0.48)",
      "backdropFilter": "blur(36px) saturate(200%) brightness(1.06)",
      "border": "1px solid rgba(255,255,255,0.09)",
      "boxShadow": "inset 0 2px 0 rgba(255,255,255,0.12), 0 0 0 0.5px rgba(200,169,107,0.20), 0 36px 90px -16px rgba(0,0,0,0.80), 0 0 130px -28px rgba(200,169,107,0.22), 0 0 90px -16px rgba(14,165,160,0.14)"
    },
    "serviceCard": {
      "extends": "glassCard",
      "width": "500px",
      "height": "540px",
      "backdropFilter": "blur(38px) saturate(215%) brightness(1.08)",
      "border": "1px solid rgba(255,255,255,0.14)",
      "boxShadow": "inset 0 1.5px 0 rgba(255,255,255,0.20), 0 0 0 0.5px rgba(200,169,107,0.24), 0 32px 72px rgba(0,0,0,0.52), 0 0 84px rgba(200,169,107,0.10), 0 0 66px rgba(14,165,160,0.08)",
      "accentColors": ["#c8a96b", "#0ea5a0"]
    },
    "reviewCard": {
      "extends": "glassCard",
      "background": "rgba(4,7,14,0.50)",
      "backdropFilter": "blur(36px) saturate(200%) brightness(1.06)",
      "border": "1px solid rgba(255,255,255,0.08)",
      "boxShadow": "inset 0 1.5px 0 rgba(255,255,255,0.12), 0 0 0 0.5px rgba(200,169,107,0.18), 0 16px 44px rgba(0,0,0,0.50), 0 0 60px rgba(200,169,107,0.055)"
    }
  },

  "liquidGlassEffects": {
    "topSpecular": {
      "height": "42%",
      "background": "linear-gradient(180deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0.025) 55%, transparent 100%)",
      "animation": "wet-pulse 7s ease-in-out infinite"
    },
    "shimmerLine": {
      "height": "1.5px",
      "background": "linear-gradient(90deg, transparent, rgba(200,169,107,0.9), rgba(255,255,255,1), rgba(14,165,160,0.9), rgba(200,169,107,0.7), transparent)",
      "animation": "liquid-shimmer 5s ease-in-out infinite"
    },
    "rainDrops": {
      "width": "1px",
      "height": "55-85px",
      "background": "linear-gradient(180deg, transparent, rgba(255,255,255,0.50), rgba(200,169,107,0.28), transparent)",
      "animation": "rain-drop 2.7-4.1s infinite at various delays"
    },
    "droplets": {
      "borderRadius": "44% 56% 58% 42% / 22% 22% 78% 78%",
      "mixBlendMode": "screen",
      "animations": ["adv-drop-slide", "adv-drop-wobble", "adv-drop-static", "adv-bubble-float"]
    }
  },

  "atmosphericEffects": {
    "cursorSpotlight": {
      "type": "fixed radial gradient",
      "size": "650px",
      "color": "rgba(200,169,107,0.07) to transparent",
      "position": "follows cursor via --cursor-x / --cursor-y CSS vars"
    },
    "noiseGrain": {
      "type": "fixed SVG fractal noise overlay",
      "opacity": "0.028",
      "animation": "grainShift 0.7s steps(1) infinite"
    },
    "scrollProgressBar": {
      "position": "fixed top",
      "height": "2px",
      "gradient": "linear-gradient(90deg, #c8a96b, #f0d080 45%, #0ea5a0)",
      "width": "tracks scroll percentage"
    },
    "backgroundOrbs": {
      "orb1": { "size": "288px", "color": "rgba(200,169,107,0.20)", "blur": "blur-3xl", "animation": "orbPulse 11s" },
      "orb2": { "size": "320px", "color": "rgba(14,165,160,0.20)", "blur": "blur-3xl", "animation": "orbPulse 15s reverse" }
    },
    "rainBackground": {
      "type": "full-screen fixed video (RainOnGlass.mp4)",
      "opacity": "0.13",
      "mixBlendMode": "screen"
    },
    "prismaticCursorOrb": {
      "size": "380px",
      "blur": "blur(85px)",
      "mixBlendMode": "screen",
      "gradient": "conic-gradient cycling through rainbow colors",
      "movement": "lerp-smoothed cursor following"
    }
  },

  "prismEffects": {
    "spectrumLine": {
      "height": "1.5px",
      "opacity": "0.50",
      "gradient": "rainbow sweep: rgba(255,0,100) -> rgba(255,165,0) -> rgba(255,255,0) -> rgba(0,255,100) -> rgba(0,150,255) -> rgba(150,0,255)",
      "animation": "spectrum-slide 5s linear infinite"
    },
    "prismRay": {
      "transform": "skewX(-18deg)",
      "gradient": "linear-gradient(90deg, transparent, rgba(255,55,55,0.065), rgba(255,200,0,0.09), rgba(0,255,145,0.08), rgba(0,145,255,0.08), rgba(195,0,255,0.06), transparent)"
    },
    "prismGlass": {
      "interaction": "mouse-following radial gradient on ::after (gold/green/blue/purple)",
      "hover": "opacity 1 + prism-card-glow 4s infinite"
    },
    "ctaPrismGlow": {
      "animation": "cta-rainbow-glow 5s ease-in-out infinite",
      "effect": "multi-colored box-shadow cycling through red/yellow/cyan/green"
    }
  },

  "spacing": {
    "containerPadding": "16px",
    "heroPadding": "px-8 md:px-16, py-10 md:py-12",
    "sectionPadding": "py-8 md:py-10 or py-10 md:py-14",
    "cardPadding": "p-6, p-7, or p-8",
    "cardGap": "gap-4, gap-6, gap-6 md:gap-8, or gap-10",
    "serviceCardSize": "500px x 540px",
    "trackPadding": "10vw left/right"
  },

  "borderRadii": {
    "glassCard": "16px",
    "heroGlass": "20px",
    "premiumBtn": "12px",
    "secondaryCta": "12px",
    "avataars": "50%",
    "droplets": "44% 56% 58% 42% / 22% 22% 78% 78%"
  },

  "gradients": {
    "premiumBtn": "linear-gradient(135deg, #c8a96b 0%, #a88442 100%)",
    "heroTopAccent": "linear-gradient(90deg, transparent, #c8a96b, #0ea5a0, transparent)",
    "goldRule": "linear-gradient(90deg, transparent, #c8a96b, transparent)",
    "featureCardAccent": "linear-gradient(90deg, transparent, rgba(200,169,107,0.6), transparent)",
    "scrollProgress": "linear-gradient(90deg, #c8a96b, #f0d080 45%, #0ea5a0)",
    "gradBorderWrap": "linear-gradient(135deg, #c8a96b, #f0d080 20%, #0ea5a0 50%, #c8a96b 80%, #f0d080)",
    "howItWorksConnector": "linear-gradient(90deg, rgba(200,169,107,0.5), rgba(14,165,160,0.5))"
  },

  "keyAnimations": [
    { "name": "heroEnter", "type": "fade + slide up", "duration": "0.72s", "easing": "cubic-bezier(0.16,1,0.3,1)" },
    { "name": "wordUp", "type": "text reveal slide up", "duration": "0.75s", "easing": "cubic-bezier(0.16,1,0.3,1)" },
    { "name": "spectrum-float", "type": "ambient orb floating", "duration": "16-19s" },
    { "name": "spectrum-slide", "type": "rainbow line translateX", "duration": "5s linear infinite" },
    { "name": "holo-sweep", "type": "gradient position shift", "duration": "5-8s" },
    { "name": "prism-ray-sweep", "type": "light ray sweep", "transform": "translateX(-130%) -> 460%" },
    { "name": "cta-rainbow-glow", "type": "box-shadow color cycle", "duration": "5s" },
    { "name": "rain-drop", "type": "vertical streak", "duration": "2.7-4.1s" },
    { "name": "wet-pulse", "type": "opacity pulse", "range": "0.55-0.85", "duration": "7s" },
    { "name": "marqueeScroll", "type": "infinite translateX", "duration": "42s" },
    { "name": "grainShift", "type": "noise jitter", "duration": "0.7s steps(1) infinite" },
    { "name": "statGlow", "type": "text-shadow + color pulse", "target": "#f0d07a", "duration": "2.6s" },
    { "name": "adv-drop-slide", "type": "complex droplet slide", "duration": "5-6s" },
    { "name": "adv-bubble-float", "type": "bubble rise", "duration": "8.5-10s" }
  ],

  "hoverEffects": {
    "featureCard": "translateY(-4px), box-shadow enhancement, 1px gold border",
    "adminSection": "translateY(-3px), prism-glass mouse-follow glow",
    "glassCard": "prism-glass ::after radial gradient reveal"
  },

  "homepageSections": {
    "hero": {
      "layout": "split: left text + right premium cards",
      "headline": "premium-heading font, large animated reveal",
      "ctaButtons": "premium-btn (gold gradient) + secondary-cta (outline)",
      "rightCard": "hero-glass card with stat numbers and service area chips"
    },
    "brandStrip": {
      "type": "marquee auto-scroll",
      "animation": "marqueeScroll 42s linear infinite"
    },
    "stats": {
      "layout": "4-column stat cards",
      "cards": "stat-card with stat-number (Cormorant Garamond) and stat-label (uppercase small)"
    },
    "services": {
      "layout": "horizontal scroll track with snap points",
      "cards": "500x540px service-liquid-card with liquid glass effects and rain drops",
      "accent": "alternating gold (#c8a96b) and teal (#0ea5a0)"
    },
    "howItWorks": {
      "layout": "vertical timeline with step numbers",
      "connector": "gradient line connecting steps"
    },
    "reviews": {
      "cards": "review-liquid card style"
    },
    "cta": {
      "style": "gradient-bordered wrap with prism glow CTA button"
    }
  }
}
